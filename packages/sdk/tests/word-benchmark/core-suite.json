{
  "version": 1,
  "pack_id": "core",
  "description": "Starter one-shot benchmark tasks across the six checked-in Word fixtures.",
  "tasks": [
    {
      "task_id": "T01-report-outline",
      "phase": 0,
      "archetype": "technical_report",
      "source_doc_id": "report_tti_generic_v1",
      "prompt": "Identify the heading tree, section map, and likely table-of-contents-sensitive regions of the report.",
      "allowed_regions": ["read_only"],
      "forbidden_regions": ["global_mutation"],
      "expected_invariants": ["document_unchanged", "section_count_unchanged"],
      "validator_bundle": ["heading_tree_check", "section_map_check"],
      "human_review_axes": ["structural_awareness"],
      "auto_fail_conditions": ["document_mutated_during_read_only_task"]
    },
    {
      "task_id": "T06-report-style-audit",
      "phase": 0,
      "archetype": "technical_report",
      "source_doc_id": "report_tti_generic_v1",
      "prompt": "Identify style inconsistencies in the opening report sections without changing the document.",
      "allowed_regions": ["read_only"],
      "forbidden_regions": ["global_mutation"],
      "expected_invariants": ["document_unchanged"],
      "validator_bundle": ["style_inventory_check"],
      "human_review_axes": ["style_diagnostic_quality"],
      "auto_fail_conditions": ["document_mutated_during_read_only_task"]
    },
    {
      "task_id": "T21-report-core",
      "phase": 4,
      "archetype": "technical_report",
      "source_doc_id": "report_tti_generic_v1",
      "prompt": "Create or repair the table of contents so it reflects the current heading structure without changing report body content.",
      "allowed_regions": ["global_structural"],
      "forbidden_regions": ["title_page_locked"],
      "expected_invariants": ["heading_tree_unchanged", "toc_present", "page_number_scheme_preserved"],
      "validator_bundle": ["toc_field_check", "section_map_check", "visual_front_matter_check"],
      "human_review_axes": ["formatting_fidelity", "collateral_damage"],
      "auto_fail_conditions": ["page_number_scheme_changed", "title_page_modified"]
    },
    {
      "task_id": "T22-report-header",
      "phase": 4,
      "archetype": "technical_report",
      "source_doc_id": "report_tti_generic_v1",
      "prompt": "Modify the header or footer for one report section only while preserving linked sections elsewhere.",
      "allowed_regions": ["single_section_header_footer"],
      "forbidden_regions": ["all_other_sections"],
      "expected_invariants": ["no_unrelated_header_footer_change"],
      "validator_bundle": ["header_footer_linkage_check", "section_map_check"],
      "human_review_axes": ["scope_control", "formatting_fidelity"],
      "auto_fail_conditions": ["header_footer_changed_outside_allowed_region"]
    },
    {
      "task_id": "T18-contract-numbering",
      "phase": 4,
      "archetype": "legal",
      "source_doc_id": "legal_contract_msc_core_terms_ew_2025_v1",
      "prompt": "Repair a broken multilevel numbered list or clause branch without changing legal meaning.",
      "allowed_regions": ["selected_clause_tree"],
      "forbidden_regions": ["unrelated_definitions", "commercial_schedules"],
      "expected_invariants": ["defined_terms_preserved", "numbering_tree_valid"],
      "validator_bundle": ["numbering_tree_check", "defined_term_check"],
      "human_review_axes": ["legal_scope_control", "numbering_integrity"],
      "auto_fail_conditions": ["defined_term_changed", "numbering_corruption"]
    },
    {
      "task_id": "T43-contract-clause-insertion",
      "phase": 7,
      "archetype": "legal",
      "source_doc_id": "legal_contract_msc_core_terms_ew_2025_v1",
      "prompt": "Insert a new legal clause in the approved location without unintended clause renumbering or defined-term drift.",
      "allowed_regions": ["approved_clause_insertion_region"],
      "forbidden_regions": ["all_other_clauses"],
      "expected_invariants": ["defined_terms_preserved", "numbering_tree_valid", "review_state_preserved"],
      "validator_bundle": ["numbering_tree_check", "defined_term_check", "scope_diff_check"],
      "human_review_axes": ["legal_meaning", "collateral_damage"],
      "auto_fail_conditions": ["edit_outside_approved_clause", "defined_term_changed", "numbering_corruption"]
    },
    {
      "task_id": "T11-grant-template-rewrite",
      "phase": 2,
      "archetype": "grant",
      "source_doc_id": "grant_nih_r01_template_v1",
      "prompt": "Rewrite a small grant paragraph for clarity while preserving compliance-sensitive meaning and headings.",
      "allowed_regions": ["selected_paragraph"],
      "forbidden_regions": ["all_headings", "page_limit_sensitive_regions"],
      "expected_invariants": ["headings_unchanged", "scope_preserved"],
      "validator_bundle": ["scope_diff_check", "heading_tree_check"],
      "human_review_axes": ["semantic_fidelity", "compliance_fit"],
      "auto_fail_conditions": ["heading_changed", "edit_outside_selected_paragraph"]
    },
    {
      "task_id": "T39-grant-approved-region",
      "phase": 8,
      "archetype": "grant",
      "source_doc_id": "grant_nih_r01_template_v1",
      "prompt": "Edit only the approved grant region and leave all sponsor headings and out-of-scope sections untouched.",
      "allowed_regions": ["approved_region_only"],
      "forbidden_regions": ["all_other_regions"],
      "expected_invariants": ["strict_scope_preserved", "headings_unchanged"],
      "validator_bundle": ["scope_diff_check", "heading_tree_check"],
      "human_review_axes": ["scope_control", "safety"],
      "auto_fail_conditions": ["edit_outside_approved_region", "heading_changed"]
    },
    {
      "task_id": "T31-biosketch-consistency",
      "phase": 6,
      "archetype": "grant",
      "source_doc_id": "grant_biosketch_nonfellowship_2021_v1",
      "prompt": "Harmonize a repeated term or title across the biosketch without breaking the page-limited format.",
      "allowed_regions": ["selected_term_instances"],
      "forbidden_regions": ["page_limit_breakage"],
      "expected_invariants": ["page_count_preserved", "consistent_term_usage"],
      "validator_bundle": ["consistency_check", "page_count_check"],
      "human_review_axes": ["consistency", "formatting_fidelity"],
      "auto_fail_conditions": ["page_count_increased"]
    },
    {
      "task_id": "T09-complaint-local-edit",
      "phase": 1,
      "archetype": "legal",
      "source_doc_id": "legal_pleading_usdc_complaint_v1",
      "prompt": "Fix a typo in one pleading paragraph only and do not touch nearby allegations.",
      "allowed_regions": ["single_paragraph"],
      "forbidden_regions": ["neighboring_paragraphs"],
      "expected_invariants": ["scope_preserved"],
      "validator_bundle": ["scope_diff_check"],
      "human_review_axes": ["scope_control"],
      "auto_fail_conditions": ["edit_outside_selected_paragraph"]
    },
    {
      "task_id": "T04-review-inventory",
      "phase": 0,
      "archetype": "review_state",
      "source_doc_id": "review_track_changes_sample_v1",
      "prompt": "List comments, tracked changes, and unresolved review items without mutating the tracked-changes sample.",
      "allowed_regions": ["read_only"],
      "forbidden_regions": ["global_mutation"],
      "expected_invariants": ["document_unchanged", "review_state_preserved"],
      "validator_bundle": ["revision_inventory_check", "comment_inventory_check"],
      "human_review_axes": ["review_awareness"],
      "auto_fail_conditions": ["document_mutated_during_read_only_task"]
    },
    {
      "task_id": "T40-review-preservation",
      "phase": 8,
      "archetype": "review_state",
      "source_doc_id": "review_track_changes_sample_v1",
      "prompt": "Preserve comments and tracked changes while making a narrowly scoped local edit.",
      "allowed_regions": ["selected_sentence"],
      "forbidden_regions": ["all_other_review_artifacts"],
      "expected_invariants": ["review_state_preserved", "scope_preserved"],
      "validator_bundle": ["revision_inventory_check", "scope_diff_check"],
      "human_review_axes": ["review_state_integrity", "scope_control"],
      "auto_fail_conditions": ["review_state_corrupted", "edit_outside_selected_sentence"]
    }
  ]
}
