{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://office-agents.local/word-benchmark/live-review.schema.json",
  "title": "Word Live Review Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_identity",
    "capability_area",
    "source_document",
    "task_id",
    "clone_id",
    "timestamp",
    "readiness_state",
    "doc_opened",
    "pane_ready",
    "bridge_session_id",
    "word_document_id",
    "execution_status",
    "duration_ms",
    "retries_used",
    "meaning_preserved",
    "scope_preserved",
    "word_native_integrity_preserved",
    "visible_layout_formatting_issues",
    "collateral_damage_observed",
    "failure_classification",
    "evidence_checked",
    "verdict",
    "score",
    "confidence",
    "freeform_observations"
  ],
  "properties": {
    "task_identity": {
      "type": "string",
      "minLength": 1
    },
    "capability_area": {
      "type": "string",
      "minLength": 1
    },
    "source_document": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "clone_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "readiness_state": {
      "type": "string",
      "enum": [
        "preflight_pending",
        "pane_open_required",
        "session_ready",
        "reviewer_running",
        "completed",
        "quarantined"
      ]
    },
    "doc_opened": {
      "type": "boolean"
    },
    "pane_ready": {
      "type": "boolean"
    },
    "bridge_session_id": {
      "type": "string",
      "minLength": 1
    },
    "word_document_id": {
      "type": "string",
      "minLength": 1
    },
    "execution_status": {
      "type": "string",
      "enum": [
        "pending",
        "paused_for_pane",
        "running",
        "rerun_pending",
        "completed",
        "failed",
        "quarantined"
      ]
    },
    "duration_ms": {
      "type": "number",
      "minimum": 0
    },
    "retries_used": {
      "type": "integer",
      "minimum": 0
    },
    "meaning_preserved": {
      "type": "boolean"
    },
    "scope_preserved": {
      "type": "boolean"
    },
    "word_native_integrity_preserved": {
      "type": "boolean"
    },
    "visible_layout_formatting_issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "collateral_damage_observed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failure_classification": {
      "type": "string",
      "minLength": 1
    },
    "evidence_checked": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "inconclusive"
      ]
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 5
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "freeform_observations": {
      "type": "string"
    }
  }
}
