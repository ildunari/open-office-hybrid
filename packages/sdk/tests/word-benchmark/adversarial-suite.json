{
  "version": 1,
  "pack_id": "adversarial",
  "description": "Recovery and ambiguity-sensitive benchmark tasks for the local Word fixtures.",
  "tasks": [
    {
      "task_id": "M01-report-section-break-recovery",
      "phase": 8,
      "archetype": "technical_report",
      "source_doc_id": "report_tti_generic_v1",
      "prompt": "Diagnose and recover from a deleted or misplaced section break without changing unrelated report sections.",
      "allowed_regions": ["damaged_section_boundary"],
      "forbidden_regions": ["all_other_sections"],
      "expected_invariants": ["page_number_scheme_preserved", "header_footer_isolation_preserved"],
      "validator_bundle": ["section_map_check", "header_footer_linkage_check", "page_number_scheme_check"],
      "human_review_axes": ["recovery_quality", "collateral_damage"],
      "auto_fail_conditions": ["header_footer_changed_outside_allowed_region", "page_number_scheme_changed"],
      "mutation_ids": ["M01"]
    },
    {
      "task_id": "M02-report-stale-field-recovery",
      "phase": 8,
      "archetype": "technical_report",
      "source_doc_id": "report_tti_generic_v1",
      "prompt": "Recover from a stale TOC or field graph while preserving report structure and front matter.",
      "allowed_regions": ["global_structural"],
      "forbidden_regions": ["title_page_locked"],
      "expected_invariants": ["toc_present", "heading_tree_unchanged"],
      "validator_bundle": ["toc_field_check", "field_inventory_check", "heading_tree_check"],
      "human_review_axes": ["recovery_quality", "formatting_fidelity"],
      "auto_fail_conditions": ["title_page_modified"],
      "mutation_ids": ["M02"]
    },
    {
      "task_id": "M05-contract-numbering-recovery",
      "phase": 8,
      "archetype": "legal",
