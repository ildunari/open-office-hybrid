      "prompt": "Recover from clause-numbering corruption without changing defined terms or unrelated clauses.",
      "allowed_regions": ["damaged_clause_tree"],
      "forbidden_regions": ["all_other_clauses"],
      "expected_invariants": ["defined_terms_preserved", "numbering_tree_valid"],
      "validator_bundle": ["numbering_tree_check", "defined_term_check", "scope_diff_check"],
      "human_review_axes": ["recovery_quality", "legal_scope_control"],
      "auto_fail_conditions": ["defined_term_changed", "edit_outside_approved_clause"],
      "mutation_ids": ["M05"]
    },
    {
      "task_id": "M07-review-state-recovery",
      "phase": 8,
      "archetype": "review_state",
      "source_doc_id": "review_track_changes_sample_v1",
      "prompt": "Diagnose a mixed review-state problem and recover without accepting or rejecting the wrong changes.",
      "allowed_regions": ["selected_review_region"],
      "forbidden_regions": ["all_other_review_regions"],
      "expected_invariants": ["review_state_preserved", "scope_preserved"],
      "validator_bundle": ["revision_inventory_check", "comment_inventory_check", "scope_diff_check"],
      "human_review_axes": ["review_state_integrity", "recovery_quality"],
      "auto_fail_conditions": ["review_state_corrupted"],
      "mutation_ids": ["M07"]
    },
    {
      "task_id": "M08-grant-protected-neighbor",
      "phase": 8,
      "archetype": "grant",
      "source_doc_id": "grant_nih_r01_template_v1",
      "prompt": "Make the requested local grant edit without touching the protected or forbidden neighboring region.",
      "allowed_regions": ["selected_grant_paragraph"],
      "forbidden_regions": ["adjacent_protected_region"],
      "expected_invariants": ["strict_scope_preserved"],
      "validator_bundle": ["scope_diff_check", "protection_integrity_check"],
      "human_review_axes": ["scope_control", "safety"],
      "auto_fail_conditions": ["protected_region_touched"],
      "mutation_ids": ["M08"]
    },
    {
