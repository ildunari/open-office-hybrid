{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://office-agents.local/word-benchmark/live-review-execution-diagnostic.schema.json",
  "title": "Word Live Review Execution Diagnostic",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_identity",
    "capability_area",
    "source_document",
    "task_id",
    "clone_id",
    "captured_at",
    "bridge_session_id",
    "word_document_id",
    "execution_classification",
    "prompt_submitted",
    "execution_observed",
    "completion_observed",
    "read_count",
    "write_count",
    "failed_write_count",
    "first_read_ts",
    "first_write_ts",
    "post_write_reread_observed",
    "no_write_loop_suspected",
    "reviewer_only_success",
    "write_attempted_but_failed",
    "write_succeeded_without_reread",
    "final_runtime_mode",
    "final_waiting_state",
    "final_verification_status",
    "degraded_guardrails"
  ],
  "properties": {
    "task_identity": { "type": "string", "minLength": 1 },
    "capability_area": { "type": "string", "minLength": 1 },
    "source_document": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "clone_id": { "type": "string", "minLength": 1 },
    "captured_at": { "type": "string", "format": "date-time" },
    "bridge_session_id": { "type": "string", "minLength": 1 },
    "word_document_id": { "type": "string", "minLength": 1 },
    "execution_classification": { "type": "string", "minLength": 1 },
    "prompt_submitted": { "type": "boolean" },
    "execution_observed": { "type": "boolean" },
    "completion_observed": { "type": "boolean" },
    "read_count": { "type": "integer", "minimum": 0 },
    "write_count": { "type": "integer", "minimum": 0 },
    "failed_write_count": { "type": "integer", "minimum": 0 },
    "first_read_ts": { "type": ["number", "null"] },
    "first_write_ts": { "type": ["number", "null"] },
    "post_write_reread_observed": { "type": "boolean" },
    "no_write_loop_suspected": { "type": "boolean" },
    "reviewer_only_success": { "type": "boolean" },
    "write_attempted_but_failed": { "type": "boolean" },
    "write_succeeded_without_reread": { "type": "boolean" },
    "final_runtime_mode": { "type": ["string", "null"] },
    "final_waiting_state": { "type": ["string", "null"] },
    "final_verification_status": { "type": ["string", "null"] },
    "degraded_guardrails": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
