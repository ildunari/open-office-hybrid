{
  "name": "@office-agents/sdk",
  "version": "0.0.5",
  "type": "module",
  "description": "Headless SDK for Office Agents — agent runtime, tools, storage, VFS, skills, OAuth, and provider config for building AI-powered Office Add-ins",
  "license": "MIT",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hewliyang/office-agents.git",
    "directory": "packages/sdk"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "catalog:",
    "@mariozechner/pi-ai": "catalog:",
    "@mozilla/readability": "^0.6.0",
    "@sinclair/typebox": "^0.34.48",
    "@types/turndown": "^5.0.6",
    "idb": "^8.0.3",
    "just-bash": "^2.7.0",
    "mammoth": "^1.11.0",
    "pdfjs-dist": "^5.4.624",
    "ses": "^1.14.0",
    "turndown": "^7.2.2",
    "xlsx": "^0.18.5"
  },
  "peerDependencies": {
    "@types/office-js": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@types/office-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/office-js": "^1.0.377"
  }
}
